import java.util.Scanner;

public class Checkout {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        float saldo = 0;
        System.out.println("Digite os dados: ");
        System.out.println("Nome: ");
        String nome = sc.nextLine();
        float compra = 0;
        while (compra < 1) {
            System.out.println("Valot bruto da compra: ");
            compra = sc.nextFloat();
        }
        int resp = 0;
        do {
            System.out.println("\n-=-=-=-=-=-=-=-=-=-=-=-=-=-\n");
            System.out.println("[1] À Vista");
            System.out.println("[2] Parelamento no Cartão(até 5x sem juros)");
            System.out.println("[3] Crediario da Loja(10 parcelas com juros de 2% ao mês sobre o valor bruto");
            System.out.println("[0] Cancelar venda");
             resp = sc.nextInt();
            switch (resp) {
                case 1:
                    saldo += (float) (compra * 0.85);
                    System.out.println("O valor a ser pago será " + saldo);
                    break;
                case 2:
                    System.out.println("Em quantas vezes voce quer parcelas? ");
                    int resposta = sc.nextInt();
                    if (resposta < 1 || resposta > 5) {
                        System.out.println("O numero de parcelas execedeu o permitido");
                    } else {
                        saldo = compra / resposta;
                        System.out.println("O valor da parcela será de " + saldo);
                    }
                    break;
                case 3:
                    saldo = (float) (compra * 1.20 / 10);
                    System.out.println("O valor da parcela será de " + saldo);
                    break;
                case 0:
                    System.out.println("Encerrando...");
                    break;
                default:
                    System.out.println("Opção invalida!");

            }
         }while (resp != 0) ;
    }
}
